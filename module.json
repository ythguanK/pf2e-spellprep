        }
    ],
    "compatibility": {
        "minimum": "13",
        "verified": "14"
    },
    "esmodules": [
        "prepper/prepper.js"
    ],
    "styles": [
        "styles/dailies.css",
        "styles/spellprep.css"
    ],
    "languages": [
        {
            "lang": "en",
